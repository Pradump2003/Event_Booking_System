{
  "info": {
    "name": "Event Booking System API",
    "description": "Postman collection for the Mini Event Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "GET - List all upcoming events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "POST - Create a new event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Node.js Workshop\",\n  \"description\": \"A hands-on workshop for Node.js beginners.\",\n  \"date\": \"2025-10-15T10:00:00.000Z\",\n  \"total_capacity\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "POST - Record Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_code\": \"YOUR_BOOKING_CODE_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/1/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["events", "1", "attendance"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "POST - Book a ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 1,\n  \"event_id\": 1,\n  \"num_tickets\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET - Get user bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/1/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "bookings"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}